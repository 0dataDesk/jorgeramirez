<style>
:root {
  --navy: #1e3a5f;
  --green: #4caf82;
  --white: #ffffff;
  --cream: #f8f9fb;
  --gray: #6b7280;
  --dark: #111827;
  --border: #e5e7eb;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:'DM Sans',sans-serif; color:var(--dark); background:var(--white); line-height:1.6; }

/* NAV */
nav { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(255,255,255,0.96); backdrop-filter:blur(8px); border-bottom:1px solid var(--border); padding:0 2rem; height:64px; display:flex; align-items:center; justify-content:space-between; }
.nav-logo { display:flex; align-items:center; gap:0.75rem; text-decoration:none; }
.nav-logo img { height:36px; width:36px; object-fit:contain; border-radius:8px; }
.nav-name { font-size:0.95rem; font-weight:600; color:var(--navy); letter-spacing:-0.01em; }
.nav-links { display:flex; gap:2rem; list-style:none; }
.nav-links a { text-decoration:none; color:var(--gray); font-size:0.875rem; font-weight:500; transition:color 0.2s; }
.nav-links a:hover { color:var(--navy); }
.nav-cta { background:var(--navy); color:var(--white); padding:0.5rem 1.25rem; border-radius:8px; text-decoration:none; font-size:0.875rem; font-weight:500; transition:background 0.2s; }
.nav-cta:hover { background:#2d5491; }

/* HERO */
.hero { min-height:100vh; background:var(--navy); display:flex; align-items:center; padding:100px 2rem 4rem; position:relative; overflow:hidden; }
.hero::before { content:''; position:absolute; top:-200px; right:-200px; width:600px; height:600px; background:radial-gradient(circle, rgba(76,175,130,0.12) 0%, transparent 70%); border-radius:50%; }
.hero::after { content:''; position:absolute; bottom:-100px; left:-100px; width:400px; height:400px; background:radial-gradient(circle, rgba(76,175,130,0.07) 0%, transparent 70%); border-radius:50%; }
.hero-inner { max-width:1100px; margin:0 auto; width:100%; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; position:relative; z-index:1; }
.hero-eyebrow { font-size:0.8rem; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; color:var(--green); margin-bottom:1.25rem; }
.hero-title { font-family:'DM Serif Display',serif; font-size:clamp(2.5rem,5vw,3.75rem); color:var(--white); line-height:1.1; margin-bottom:1.5rem; letter-spacing:-0.02em; }
.hero-title em { font-style:italic; color:var(--green); }
.hero-sub { font-size:1.05rem; color:rgba(255,255,255,0.7); margin-bottom:2.5rem; line-height:1.7; max-width:480px; }
.hero-actions { display:flex; gap:1rem; flex-wrap:wrap; }
.btn-primary { display:inline-flex; align-items:center; gap:0.5rem; background:var(--green); color:var(--white); padding:0.875rem 1.75rem; border-radius:10px; text-decoration:none; font-weight:600; font-size:0.95rem; transition:all 0.2s; box-shadow:0 4px 20px rgba(76,175,130,0.3); }
.btn-primary:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(76,175,130,0.4); }
.btn-ghost { display:inline-flex; align-items:center; gap:0.5rem; border:1.5px solid rgba(255,255,255,0.25); color:rgba(255,255,255,0.8); padding:0.875rem 1.75rem; border-radius:10px; text-decoration:none; font-weight:500; font-size:0.95rem; transition:all 0.2s; }
.btn-ghost:hover { border-color:rgba(255,255,255,0.6); color:var(--white); }
.hero-visual { display:flex; justify-content:center; align-items:center; }
.hero-card { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:24px; padding:2.5rem; backdrop-filter:blur(8px); text-align:center; }
.hero-card img { width:160px; height:160px; object-fit:contain; border-radius:16px; display:block; margin:0 auto 1.5rem; }
.hero-card-name { font-family:'DM Serif Display',serif; font-size:1.75rem; color:var(--white); letter-spacing:-0.02em; line-height:1.1; margin-bottom:0.4rem; }
.hero-card-tagline { font-size:0.875rem; color:var(--green); font-weight:500; }
.hero-card-tagline span { color:rgba(255,255,255,0.35); margin:0 0.35rem; }

/* SECCIONES */
section { padding:6rem 2rem; }
.section-inner { max-width:1100px; margin:0 auto; }
.section-tag { display:inline-block; font-size:0.75rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--green); margin-bottom:1rem; }
.section-title { font-family:'DM Serif Display',serif; font-size:clamp(2rem,4vw,2.75rem); color:var(--navy); line-height:1.15; letter-spacing:-0.02em; margin-bottom:1.5rem; }
.section-lead { font-size:1.1rem; color:var(--gray); max-width:600px; line-height:1.75; }

/* DIAGNÓSTICO */
.diagnostico { background:var(--cream); }
.dolor-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin:3rem 0; }
.dolor-card { background:var(--white); border:1px solid var(--border); border-radius:14px; padding:1.75rem; position:relative; overflow:hidden; }
.dolor-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:var(--green); }
.dolor-num { font-size:2rem; font-weight:700; color:rgba(30,58,95,0.07); font-family:'DM Serif Display',serif; position:absolute; top:1rem; right:1.25rem; line-height:1; }
.dolor-card h3 { font-size:1rem; font-weight:600; color:var(--navy); margin-bottom:0.5rem; }
.dolor-card p { font-size:0.9rem; color:var(--gray); line-height:1.6; }
.solucion-box { background:var(--navy); border-radius:16px; padding:2.5rem; display:flex; gap:2rem; align-items:center; margin-top:1rem; }
.solucion-box-icon { font-size:2.5rem; flex-shrink:0; }
.solucion-box h3 { font-size:1.1rem; font-weight:600; color:var(--white); margin-bottom:0.5rem; }
.solucion-box p { font-size:0.9rem; color:rgba(255,255,255,0.65); line-height:1.6; }

/* CÓMO TRABAJO */
.patron-steps { display:flex; flex-direction:column; gap:0; margin:3rem 0; position:relative; }
.patron-steps::before { content:''; position:absolute; left:24px; top:32px; bottom:32px; width:2px; background:linear-gradient(to bottom, var(--green), rgba(76,175,130,0.1)); }
.patron-step { display:flex; gap:2rem; padding:1.5rem 0; position:relative; }
.step-dot { width:50px; height:50px; flex-shrink:0; background:var(--white); border:2px solid var(--green); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; font-weight:700; color:var(--green); font-family:'DM Serif Display',serif; position:relative; z-index:1; }
.step-content { padding-top:0.5rem; }
.step-content h3 { font-size:1rem; font-weight:600; color:var(--navy); margin-bottom:0.35rem; }
.step-content p { font-size:0.9rem; color:var(--gray); line-height:1.6; max-width:520px; }
.credencial-box { background:linear-gradient(135deg, var(--navy) 0%, #2d5491 100%); border-radius:16px; padding:2.5rem; margin-top:2rem; border-left:4px solid var(--green); }
.credencial-box p { font-size:1rem; color:rgba(255,255,255,0.85); line-height:1.75; font-style:italic; }
.credencial-box span { display:block; margin-top:1rem; font-size:0.85rem; color:var(--green); font-weight:500; font-style:normal; }

/* SERVICIOS */
.servicios { background:var(--cream); }
.servicios-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-top:3rem; }
.servicio-card { background:var(--white); border:1px solid var(--border); border-radius:16px; padding:2rem; transition:box-shadow 0.2s; }
.servicio-card:hover { box-shadow:0 8px 32px rgba(0,0,0,0.08); }
.servicio-icon { font-size:2rem; margin-bottom:1rem; }
.servicio-card h3 { font-size:1.1rem; font-weight:600; color:var(--navy); margin-bottom:0.5rem; }
.precio { font-family:'DM Serif Display',serif; font-size:1.5rem; color:var(--green); margin:1rem 0 0.35rem; }
.precio-nota { font-size:0.8rem; color:var(--gray); margin-bottom:1rem; }
.servicio-items { list-style:none; display:flex; flex-direction:column; gap:0.5rem; }
.servicio-items li { font-size:0.875rem; color:var(--gray); display:flex; align-items:flex-start; gap:0.5rem; }
.servicio-items li::before { content:'✓'; color:var(--green); font-weight:700; flex-shrink:0; }
.membresia-card { background:var(--navy); border-radius:16px; padding:2.5rem; margin-top:2rem; grid-column:1/-1; display:grid; grid-template-columns:1fr auto; gap:2rem; align-items:center; }
.membresia-card h3 { font-family:'DM Serif Display',serif; font-size:1.5rem; color:var(--white); margin-bottom:0.75rem; }
.membresia-card p { font-size:0.95rem; color:rgba(255,255,255,0.7); line-height:1.7; max-width:550px; }
.membresia-precio { text-align:center; flex-shrink:0; }
.monto { font-family:'DM Serif Display',serif; font-size:3rem; color:var(--green); line-height:1; }
.periodo { font-size:0.85rem; color:rgba(255,255,255,0.5); margin-top:0.25rem; }

/* TRABAJOS */
.trabajos-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; margin-top:3rem; }
.trabajo-card { border-radius:16px; overflow:hidden; border:1px solid var(--border); transition:transform 0.2s, box-shadow 0.2s; background:var(--white); }
.trabajo-card:hover { transform:translateY(-4px); box-shadow:0 16px 48px rgba(0,0,0,0.12); }
.trabajo-img { width:100%; aspect-ratio:16/10; object-fit:cover; display:block; }
.trabajo-info { padding:1.25rem 1.5rem; }
.trabajo-tag { font-size:0.7rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--green); margin-bottom:0.35rem; display:block; }
.trabajo-info h3 { font-size:0.95rem; font-weight:600; color:var(--navy); margin-bottom:0.25rem; }
.trabajo-info p { font-size:0.8rem; color:var(--gray); line-height:1.5; }
.trabajo-card.wide { grid-column:1/-1; }
.trabajo-card.wide .trabajo-img { aspect-ratio:21/7; }

/* PROCESO */
.proceso { background:var(--cream); }
.proceso-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; margin-top:3rem; }
.proceso-step { text-align:center; padding:2rem 1.5rem; background:var(--white); border-radius:16px; border:1px solid var(--border); position:relative; }
.proceso-step::after { content:'→'; position:absolute; right:-1rem; top:50%; transform:translateY(-50%); color:var(--green); font-size:1.25rem; font-weight:700; z-index:1; }
.proceso-step:last-child::after { display:none; }
.proceso-num { font-family:'DM Serif Display',serif; font-size:3rem; color:rgba(30,58,95,0.06); line-height:1; margin-bottom:0.5rem; }
.proceso-step h3 { font-size:0.95rem; font-weight:600; color:var(--navy); margin-bottom:0.5rem; }
.proceso-step p { font-size:0.8rem; color:var(--gray); line-height:1.5; }

/* CONTACTO */
.contacto { background:var(--navy); }
.contacto .section-title { color:var(--white); }
.contacto .section-lead { color:rgba(255,255,255,0.65); }
.contacto-box { margin-top:3rem; display:flex; flex-direction:column; align-items:flex-start; gap:1.5rem; }
.wa-btn { display:inline-flex; align-items:center; gap:0.75rem; background:#25d366; color:var(--white); padding:1rem 2rem; border-radius:12px; text-decoration:none; font-weight:600; font-size:1.05rem; transition:all 0.2s; box-shadow:0 4px 20px rgba(37,211,102,0.35); }
.wa-btn:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(37,211,102,0.45); }
.wa-btn svg { width:24px; height:24px; fill:white; }
.contacto-nota { font-size:0.875rem; color:rgba(255,255,255,0.45); }

/* FOOTER */
footer { background:#0f1f35; padding:2rem; text-align:center; }
footer p { font-size:0.8rem; color:rgba(255,255,255,0.3); }
footer span { color:var(--green); }

/* RESPONSIVE */
@media (max-width:900px) {
  .hero-inner { grid-template-columns:1fr; }
  .hero-visual { display:none; }
  .dolor-grid { grid-template-columns:1fr; }
  .servicios-grid { grid-template-columns:1fr; }
  .trabajos-grid { grid-template-columns:1fr; }
  .proceso-grid { grid-template-columns:1fr 1fr; }
  .proceso-step::after { display:none; }
  .membresia-card { grid-template-columns:1fr; text-align:center; }
  .nav-links { display:none; }
  .trabajo-card.wide { grid-column:1; }
}

.fade-in { opacity:0; transform:translateY(24px); transition:opacity 0.6s ease, transform 0.6s ease; }
.fade-in.visible { opacity:1; transform:translateY(0); }
</style>
</head>
